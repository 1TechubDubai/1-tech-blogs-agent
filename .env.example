# Application Configuration
APP_NAME=Autonomous SEO Operations Engine
ENVIRONMENT=development

# Testing Mode - Set to True to write blogs to files instead of Firebase
USE_FILE_STORAGE=false
TEST_STORAGE_PATH=./test_output

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Google APIs
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token
RAPIDAPI_KEY=c83210c3fdmsh36782caf2862e4cp179581jsn5c571e58597e
GOOGLE_CUSTOM_SEARCH_API_KEY=your-custom-search-api-key
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=your-search-engine-id

# Gemini / Vertex AI
GEMINI_API_KEY=your-gemini-api-key
VERTEX_AI_LOCATION=us-central1

# Firebase / Firestore
# If deployed to Cloud Run, GCP handles authentication automatically
# For local development, set GOOGLE_APPLICATION_CREDENTIALS above
